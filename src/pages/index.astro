---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { SITE_URL } from "../config/site";

const pageTitle = "Pneumaris";
const pageDescription = "Pneumaris — atmospheric music from the void. Listen on SoundCloud.";
const canonicalUrl = `${SITE_URL}/`;
const socialImageUrl = `${SITE_URL}/header.png`;
const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": `${SITE_URL}/#website`,
			url: canonicalUrl,
			name: "Pneumaris",
			description: pageDescription,
			inLanguage: "en",
		},
		{
			"@type": "MusicGroup",
			"@id": `${SITE_URL}/#musicgroup`,
			url: canonicalUrl,
			name: "Pneumaris",
			description: pageDescription,
			image: socialImageUrl,
			sameAs: [
				"https://soundcloud.com/pneumaris",
				"https://www.youtube.com/@Pneumaris",
				"https://www.tiktok.com/@pneumaris",
				"https://x.com/pneumarisband",
				"https://www.instagram.com/pneumaris/",
				"https://www.facebook.com/profile.php?id=61589446647657",
			],
		},
	],
};
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<link rel="stylesheet" href="/universal.css" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content="Pneumaris" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={socialImageUrl} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
		<style>
			.hero {
				position: relative;
				width: 100%;
				min-height: clamp(480px, 58vw, 680px);
				display: flex;
				align-items: flex-end;
				overflow: hidden;
			}

			.hero-bg {
				position: absolute;
				inset: 0;
				background: url('/header.png') center 25% / cover no-repeat;
				filter: brightness(0.55);
				z-index: 0;
			}

			.hero-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(6, 4, 2, 0.1) 0%,
					rgba(6, 4, 2, 0.0) 40%,
					rgba(6, 4, 2, 0.75) 80%,
					rgba(6, 4, 2, 1) 100%
				);
				z-index: 1;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				padding: clamp(2rem, 5vw, 4rem) clamp(1.1rem, 3vw, 2.4rem);
				max-width: 1280px;
				margin: 0 auto;
				width: 100%;
			}

			.hero-eyebrow {
				font-family: "Cinzel", serif;
				font-size: 0.72rem;
				letter-spacing: 0.3em;
				text-transform: uppercase;
				color: var(--gold-dim);
				margin-bottom: 0.75rem;
			}

			.hero-title {
				font-family: "Cinzel", serif;
				font-size: clamp(3rem, 8vw, 6.5rem);
				font-weight: 600;
				letter-spacing: 0.18em;
				color: var(--gold-bright);
				line-height: 1;
				text-shadow: 0 2px 32px rgba(0,0,0,0.7);
				margin-bottom: 1.2rem;
			}

			.hero-sub {
				font-size: clamp(0.95rem, 2vw, 1.15rem);
				font-weight: 300;
				font-style: italic;
				color: rgba(232, 224, 212, 0.65);
				max-width: 48ch;
				line-height: 1.6;
				margin-bottom: 2rem;
			}

			.hero-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0.75rem 1.75rem;
				border: 1px solid var(--gold-dim);
				border-radius: 0.3rem;
				font-family: "Cinzel", serif;
				font-size: 0.78rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--gold-bright);
				background: rgba(6, 4, 2, 0.5);
				backdrop-filter: blur(6px);
				transition: background 200ms ease, border-color 200ms ease;
			}

			.hero-cta:hover {
				background: rgba(184, 154, 106, 0.12);
				border-color: var(--gold);
				color: var(--gold-bright);
			}

			.section-heading {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				margin-bottom: 2rem;
			}

			.section-heading h2 {
				font-size: clamp(1.1rem, 2.5vw, 1.5rem);
				white-space: nowrap;
			}

			.section-heading-line {
				flex: 1;
				height: 1px;
				background: linear-gradient(90deg, var(--line), transparent);
			}

			/* Intro blurb */
			.intro-section {
				max-width: 1280px;
				margin: 0 auto;
				padding: 3.5rem clamp(1.1rem, 3vw, 2.4rem) 0;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: clamp(2rem, 4vw, 4rem);
				align-items: center;
			}

			.intro-text p + p {
				margin-top: 1.1rem;
			}

			.intro-text p {
				color: rgba(232, 224, 212, 0.72);
				font-size: 1.05rem;
			}

			.intro-logo {
				display: flex;
				justify-content: center;
			}

			.intro-logo img {
				width: min(100%, 320px);
				height: auto;
				opacity: 0.88;
				filter: drop-shadow(0 0 40px rgba(184, 154, 106, 0.15));
			}

			@media (max-width: 720px) {
				.intro-section {
					grid-template-columns: 1fr;
				}

				.intro-logo {
					order: -1;
				}

				.intro-logo img {
					width: min(100%, 220px);
				}
			}
		</style>
	</head>
	<body>
		<SiteHeader active="home" />

		<main>
			<!-- Hero -->
			<section class="hero" aria-label="Hero">
				<div class="hero-bg" aria-hidden="true"></div>
				<div class="hero-overlay" aria-hidden="true"></div>
				<div class="hero-content">
					<p class="hero-eyebrow">Enter the void</p>
					<h1 class="hero-title">Pneumaris</h1>
					<p class="hero-sub">Atmospheric soundscapes forged from shadow and resonance.</p>
					<a class="hero-cta" href="/music">
						Listen Now
					</a>
				</div>
			</section>

			<!-- Intro -->
			<section class="intro-section">
				<div class="intro-text">
					<div class="section-heading">
						<h2>The Band</h2>
						<div class="section-heading-line" aria-hidden="true"></div>
					</div>
					<p>
						Pneumaris is an atmospheric project that dwells in the space between
					silence and fury — conjuring crushing riffs, haunting
						melodies, and an air of the esoteric.
					</p>
					<p>
					Each release is an invitation to descend into the dark —
					where the weight of the music hits as hard as it haunts.
					</p>
				</div>
				<div class="intro-logo">
					<img src="/logo-circle.png" alt="Pneumaris logo" loading="lazy" decoding="async" />
				</div>
			</section>
		</main>

		<SiteFooter />
	</body>
</html>
