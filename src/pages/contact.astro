---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<link rel="stylesheet" href="/universal.css" />
		<meta name="generator" content={Astro.generator} />
		<title>Contact — Pneumaris</title>
		<meta name="description" content="Get in touch with Pneumaris." />
		<style>
			.page-header {
				border-bottom: 1px solid var(--line);
				padding: 3.5rem clamp(1.1rem, 3vw, 2.4rem) 2.5rem;
				background: linear-gradient(to bottom, rgba(60, 40, 12, 0.08), transparent);
			}

			.page-header-inner {
				max-width: 1280px;
				margin: 0 auto;
			}

			.page-header .section-label {
				margin-bottom: 0.6rem;
				display: block;
			}

			.page-header h1 {
				font-size: clamp(2rem, 5vw, 3.5rem);
			}

			.content {
				max-width: 680px;
				margin: 0 auto;
				padding: 3.5rem clamp(1.1rem, 3vw, 2.4rem);
			}

			.contact-intro {
				color: rgba(232, 224, 212, 0.65);
				font-size: 1.05rem;
				margin-bottom: 2.5rem;
				line-height: 1.8;
			}

			.links-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.contact-link {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1.1rem 1.4rem;
				border: 1px solid var(--line);
				border-radius: 0.4rem;
				color: var(--ink-soft);
				font-family: "Cinzel", serif;
				font-size: 0.82rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				transition: border-color 180ms ease, color 180ms ease, background 180ms ease;
			}

			.contact-link:hover {
				border-color: var(--gold-dim);
				color: var(--gold-bright);
				background: rgba(184, 154, 106, 0.05);
			}

			.contact-link span {
				opacity: 0.4;
				font-size: 0.9rem;
			}
		</style>
	</head>
	<body>
		<SiteHeader active="contact" />

		<main>
			<div class="page-header">
				<div class="page-header-inner">
					<span class="section-label">Reach Out</span>
					<h1>Contact</h1>
				</div>
			</div>

			<div class="content">
				<p class="contact-intro">
					For booking, press inquiries, collaborations, or anything else —
					reach through the following channels.
				</p>

				<div class="links-list">
					<a
						class="contact-link"
						href="https://soundcloud.com/pneumaris"
						target="_blank"
						rel="noopener noreferrer"
					>
						SoundCloud
						<span>↗</span>
					</a>
				</div>
			</div>
		</main>

		<SiteFooter />
	</body>
</html>
