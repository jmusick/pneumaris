---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface AlbumTrack {
	title: string;
	url: string;
	duration: string;
	artwork: string;
}

interface Album {
	title: string;
	type: string;
	year: string;
	releaseDate: string;
	description: string;
	artwork: string;
	albumUrl: string;
	embedUrl: string;
	tracks: AlbumTrack[];
