---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="viewport" content="width=device-width" />
		<link rel="stylesheet" href="/universal.css" />
		<meta name="generator" content={Astro.generator} />
		<title>Privacy Policy — Pneumaris</title>
		<meta name="description" content="Privacy Policy for the Pneumaris website." />
		<style>
			.page-header {
				border-bottom: 1px solid var(--line);
				padding: 3.5rem clamp(1.1rem, 3vw, 2.4rem) 2.5rem;
				background: linear-gradient(to bottom, rgba(60, 40, 12, 0.08), transparent);
			}

			.page-header-inner {
				max-width: 1280px;
				margin: 0 auto;
			}

			.page-header .section-label {
				margin-bottom: 0.6rem;
				display: block;
			}

			.page-header h1 {
				font-size: clamp(2rem, 5vw, 3.5rem);
			}

			.content {
				max-width: 720px;
				margin: 0 auto;
				padding: 3.5rem clamp(1.1rem, 3vw, 2.4rem);
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.content p,
			.content li {
				color: rgba(232, 224, 212, 0.72);
				font-size: 1.05rem;
				line-height: 1.8;
			}

			.content h2 {
				font-size: 1.05rem;
				margin-bottom: 0.5rem;
			}

			.content ul {
				margin: 0;
				padding-left: 1.4rem;
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}

			.policy-block {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.last-updated {
				font-size: 0.82rem;
				color: var(--ink-muted);
				letter-spacing: 0.05em;
			}
		</style>
	</head>
	<body>
		<SiteHeader />

		<main>
			<div class="page-header">
				<div class="page-header-inner">
					<span class="section-label">Legal</span>
					<h1>Privacy Policy</h1>
				</div>
			</div>

			<div class="content">
				<p class="last-updated">Last updated: May 11, 2026</p>

				<div class="policy-block">
					<h2>Overview</h2>
					<p>
						This website (<strong>pneumaris.com</strong>) is operated by Pneumaris.
						We are committed to protecting your privacy. This policy outlines what
						information, if any, is collected when you visit this site and how it
						is used.
					</p>
				</div>

				<div class="policy-block">
					<h2>Information We Collect</h2>
					<p>
						If you use the contact form, we collect the information you submit:
						name, email address, subject, and message content. This information is
						used only to review and respond to your inquiry.
					</p>
					<p>
						We also use a hidden anti-spam field and CAPTCHA verification to help
						prevent automated abuse of the form.
					</p>
				</div>

				<div class="policy-block">
					<h2>Analytics</h2>
					<p>
						This website uses <strong>Cloudflare Web Analytics</strong> to measure
						aggregate traffic and site performance (for example, page views,
						referrers, browser/device categories, and country-level trends).
					</p>
					<p>
						Cloudflare Web Analytics is designed to be privacy-friendly and does
						not rely on client-side advertising cookies for basic reporting. See
						the
						<a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare Privacy Policy</a>.
					</p>
				</div>

				<div class="policy-block">
					<h2>Third-Party Services</h2>
					<p>
						This site embeds content from third-party platforms that may collect
						data independently under their own privacy policies:
					</p>
					<ul>
						<li>
							<strong>Cloudflare Web Analytics</strong> — used to measure
							aggregate site usage and performance trends. See the
							<a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare Privacy Policy</a>.
						</li>
						<li>
							<strong>Web3Forms</strong> — used to process contact form
							submissions and deliver them to Pneumaris. See the
							<a href="https://web3forms.com/privacy" target="_blank" rel="noopener noreferrer">Web3Forms Privacy Policy</a>.
						</li>
						<li>
							<strong>hCaptcha</strong> — used to protect the contact form from
							spam and abuse. hCaptcha may process technical and behavioral data to
							perform bot detection. See the
							<a href="https://www.hcaptcha.com/privacy" target="_blank" rel="noopener noreferrer">hCaptcha Privacy Policy</a>.
						</li>
						<li>
							<strong>SoundCloud</strong> — used to stream music. SoundCloud may set
							cookies and collect usage data. See the
							<a href="https://soundcloud.com/pages/privacy" target="_blank" rel="noopener noreferrer">SoundCloud Privacy Policy</a>.
						</li>
						<li>
							<strong>Google Fonts</strong> — used to load typefaces. Google may log
							requests made to their font servers. See the
							<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google Privacy Policy</a>.
						</li>
					</ul>
				</div>

				<div class="policy-block">
					<h2>Cookies</h2>
					<p>
						This website does not set its own analytics cookies. Third-party
						services listed above, including SoundCloud and hCaptcha, may set
						cookies or similar technologies subject to their own policies.
					</p>
				</div>

				<div class="policy-block">
					<h2>External Links</h2>
					<p>
						This site may link to external websites. We are not responsible for
						the privacy practices or content of those sites.
					</p>
				</div>

				<div class="policy-block">
					<h2>Changes to This Policy</h2>
					<p>
						We may update this policy from time to time. Any changes will be
						reflected on this page with an updated date.
					</p>
				</div>

				<div class="policy-block">
					<h2>Contact</h2>
					<p>
						For any privacy-related questions, please reach out via our
						<a href="/contact">contact page</a>.
					</p>
				</div>
			</div>
		</main>

		<SiteFooter />
	</body>
</html>
